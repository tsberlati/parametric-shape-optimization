FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0";
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform 101325; 

boundaryField
{
    inlet
    {
        type            totalPressure;
        rho             rho;
        psi             thermo:psi;
        gamma           1.1398;
        p0              uniform 2915385;
        value           uniform 2828482;
    }
    outlet
    {
        type            waveTransmissive;
        field           p;
        phi             phi;
        rho             rho;
        psi             thermo:psi;
        gamma           1.1398;
        fieldInf        101325;
        lInf            0.537;
        value           uniform 101325;
    }
    walls
    {
        type            zeroGradient;
    }
    farfield
    {
        type            waveTransmissive;
        field           p;
        phi             phi;
        rho             rho;
        psi             thermo:psi;
        gamma           1.1398;
        fieldInf        101325;
        lInf            0.35;
        value           uniform 101325;
    }
    axis
    {
        type            empty;
    }
    front
    {
        type            wedge;
    }
    back
    {
        type            wedge;
    }
}

