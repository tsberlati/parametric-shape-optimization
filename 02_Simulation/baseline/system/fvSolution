FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    // Equazioni governanti esplicite (Massa, Quantità di moto, Energia totale)
    "(rho|rhoU|rhoE).*"
    {
        solver          diagonal;
    }

    // Correzioni viscose implicite
    "(U|e).*"
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-08;
        relTol          0.1;
    }

    // Risolutore per la turbolenza ottimizzato per strati limite
    "(k|omega).*"
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-08;
        relTol          0.1;
    }
}

